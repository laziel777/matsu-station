rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPostImageUpload(maxBytes) {
      return request.resource != null
             && request.resource.size <= maxBytes
             && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow create: if isOwner(userId)
                    && fileName.matches('[0-9]{13}_avatar\\.jpg')
                    && isPostImageUpload(1048576);
      allow delete: if isOwner(userId);
      allow update: if false;
    }

    match /posts/{userId}/{fileName} {
      allow read: if true;
      allow create: if isOwner(userId)
                    && fileName.matches('[0-9]{13}_[a-z0-9]{6,16}\\.(jpg|jpeg|png|webp)')
                    && isPostImageUpload(10485760);
      allow delete: if isOwner(userId);
      allow update: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
