rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isStationMaster() {
      return isSignedIn() && request.auth.uid == 'gHHxF8p1DnbMkoeVmU5XpB18Elz2';
    }

    function hasAcceptedCurrentPolicies() {
      return isSignedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agreedToTerms == true
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isProfileSetup == true
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.acceptedTermsVersion == '2026-05-19'
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.acceptedPrivacyVersion == '2026-05-19'
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.acceptedCommunityRulesVersion == '2026-05-19';
    }

    function hasValidContent(maxLength) {
      return request.resource.data.content is string
             && request.resource.data.content.size() <= maxLength;
    }

    function hasValidFightFields() {
      return !request.resource.data.keys().hasAny(['fightMode', 'userRiskLabel'])
             || (
               request.resource.data.keys().hasAll(['fightMode', 'userRiskLabel'])
               && request.resource.data.fightMode is bool
               && request.resource.data.userRiskLabel in ['normal', 'fight']
               && (
                 (request.resource.data.fightMode == true
                  && request.resource.data.userRiskLabel == 'fight')
                 || (request.resource.data.fightMode == false
                     && request.resource.data.userRiskLabel == 'normal')
               )
             );
    }

    function hasOnlyPostCreateFields() {
      return request.resource.data.keys().hasOnly([
        'authorId', 'authorName', 'authorPhoto', 'content', 'category',
        'aiSafe', 'aiRisk', 'aiTag', 'aiSummary', 'aiAction',
        'fightMode', 'userRiskLabel',
        'likesCount', 'commentsCount', 'reportsCount', 'imageUrls', 'createdAt'
      ]);
    }

    function hasOnlyCommentCreateFields() {
      return request.resource.data.keys().hasOnly([
        'authorId', 'authorName', 'authorPhoto', 'authorRole',
        'content', 'fightMode', 'userRiskLabel', 'likesCount', 'repliesCount', 'createdAt'
      ]);
    }

    function hasOnlyReplyCreateFields() {
      return request.resource.data.keys().hasOnly([
        'authorId', 'authorName', 'authorPhoto', 'authorRole',
        'content', 'fightMode', 'userRiskLabel', 'likesCount', 'createdAt'
      ]);
    }

    function hasOnlyReportCreateFields() {
      return request.resource.data.keys().hasOnly([
        'targetId', 'targetType', 'postId', 'commentId', 'replyId',
        'targetPreview', 'reporterId', 'reporterName',
        'reason', 'status', 'createdAt'
      ]);
    }

    function hasOnlyNotificationCreateFields() {
      return request.resource.data.keys().hasOnly([
        'recipientId', 'senderId', 'senderName', 'type',
        'postId', 'category', 'commentId', 'replyId',
        'title', 'content', 'read', 'createdAt'
      ]);
    }

    function hasValidReactionFields() {
      return request.resource.data.keys().hasOnly(['reaction', 'createdAt', 'updatedAt'])
             && request.resource.data.reaction is string
             && request.resource.data.reaction.size() <= 4;
    }

    function hasValidUserCreateFields(userId) {
      return request.resource.data.keys().hasOnly([
               'uid', 'islanderId', 'displayName', 'photoURL', 'role',
               'agreedToTerms', 'acceptedTermsVersion', 'acceptedPrivacyVersion',
               'acceptedCommunityRulesVersion', 'policyAcceptedAt',
               'isProfileSetup', 'createdAt'
             ])
             && request.resource.data.uid == userId
             && request.resource.data.islanderId is string
             && request.resource.data.displayName is string
             && request.resource.data.role in ['user', 'admin']
             && (
               (isStationMaster()
                && userId == 'gHHxF8p1DnbMkoeVmU5XpB18Elz2'
                && request.resource.data.role == 'admin'
                && request.resource.data.islanderId == 'L')
               || (!isStationMaster()
                   && request.resource.data.role == 'user'
                   && request.resource.data.islanderId != 'L')
             );
    }

    function hasValidAuthorRole() {
      return (isStationMaster() && request.resource.data.authorRole == 'admin')
             || (!isStationMaster() && request.resource.data.authorRole == 'user');
    }

    function hasValidFollowingFields(targetUserId) {
      return request.resource.data.keys().hasOnly([
               'targetUserId', 'islanderId', 'displayName', 'photoURL', 'createdAt'
             ])
             && request.resource.data.targetUserId == targetUserId
             && request.resource.data.islanderId is string
             && request.resource.data.displayName is string;
    }

    function hasValidFollowerFields(followerId) {
      return request.resource.data.keys().hasOnly([
               'followerId', 'islanderId', 'displayName', 'photoURL', 'createdAt'
             ])
             && request.resource.data.followerId == followerId
             && request.resource.data.islanderId is string
             && request.resource.data.displayName is string;
    }

    function hasValidFollowRequestFields(requesterId) {
      return request.resource.data.keys().hasOnly([
               'requesterId', 'islanderId', 'displayName', 'photoURL', 'status', 'createdAt'
             ])
             && request.resource.data.requesterId == requesterId
             && request.resource.data.islanderId is string
             && request.resource.data.displayName is string
             && request.resource.data.status == 'pending';
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || isStationMaster();
      allow create: if isOwner(userId) && hasValidUserCreateFields(userId);
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'agreedToTerms', 'isProfileSetup', 'displayName',
                      'photoURL', 'bio', 'title', 'lastProfileUpdate',
                      'acceptedTermsVersion', 'acceptedPrivacyVersion',
                      'acceptedCommunityRulesVersion', 'policyAcceptedAt'
                    ]);

      match /following/{targetUserId} {
        allow read: if isSignedIn();
        allow create, update: if hasAcceptedCurrentPolicies()
                              && isOwner(targetUserId)
                              && hasValidFollowingFields(targetUserId)
                              && exists(/databases/$(database)/documents/users/$(targetUserId)/followRequests/$(userId));
        allow delete: if isOwner(userId) || isOwner(targetUserId);
      }

      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create, update: if hasAcceptedCurrentPolicies()
                              && isOwner(userId)
                              && hasValidFollowerFields(followerId)
                              && exists(/databases/$(database)/documents/users/$(userId)/followRequests/$(followerId));
        allow delete: if isOwner(followerId) || isOwner(userId);
      }

      match /followRequests/{requesterId} {
        allow get: if isOwner(userId) || isOwner(requesterId);
        allow list: if isOwner(userId);
        allow create, update: if hasAcceptedCurrentPolicies()
                              && isOwner(requesterId)
                              && hasValidFollowRequestFields(requesterId);
        allow delete: if isOwner(userId) || isOwner(requesterId);
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && hasAcceptedCurrentPolicies()
                    && hasOnlyPostCreateFields()
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.likesCount == 0
                    && request.resource.data.commentsCount == 0
                    && request.resource.data.reportsCount == 0
                    && hasValidFightFields()
                    && hasValidContent(500);
      allow update: if false;
      allow delete: if isOwner(resource.data.authorId);

      match /likes/{userId} {
        allow read: if true;
        allow create, update: if hasAcceptedCurrentPolicies() && isOwner(userId) && hasValidReactionFields();
        allow delete: if isOwner(userId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
                      && hasAcceptedCurrentPolicies()
                      && hasOnlyCommentCreateFields()
                      && request.resource.data.authorId == request.auth.uid
                      && hasValidAuthorRole()
                      && request.resource.data.likesCount == 0
                      && request.resource.data.repliesCount == 0
                      && hasValidFightFields()
                      && hasValidContent(250);
        allow update: if false;
        allow delete: if isOwner(resource.data.authorId);

        match /likes/{userId} {
          allow read: if true;
          allow create, update: if hasAcceptedCurrentPolicies() && isOwner(userId) && hasValidReactionFields();
          allow delete: if isOwner(userId);
        }

        match /replies/{replyId} {
          allow read: if true;
          allow create: if isSignedIn()
                        && hasAcceptedCurrentPolicies()
                        && hasOnlyReplyCreateFields()
                        && request.resource.data.authorId == request.auth.uid
                        && hasValidAuthorRole()
                        && request.resource.data.likesCount == 0
                        && hasValidFightFields()
                        && hasValidContent(250);
          allow update: if false;
          allow delete: if isOwner(resource.data.authorId);

          match /likes/{userId} {
            allow read: if true;
            allow create, update: if hasAcceptedCurrentPolicies() && isOwner(userId) && hasValidReactionFields();
            allow delete: if isOwner(userId);
          }
        }
      }
    }

    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && hasAcceptedCurrentPolicies()
                    && hasOnlyReportCreateFields()
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.targetId is string
                    && request.resource.data.targetType in ['post', 'comment', 'reply']
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() <= 500
                    && request.resource.data.status == 'pending';
      allow read, update, delete: if false;
    }

    match /aiPatrolLogs/{logId} {
      allow read: if isAdmin() || isStationMaster();
      allow write: if false;
    }

    match /moderationCases/{caseId} {
      allow read: if isAdmin() || isStationMaster()
                  || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn()
                    && hasAcceptedCurrentPolicies()
                    && hasOnlyNotificationCreateFields()
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.recipientId is string
                    && request.resource.data.type in ['like', 'comment', 'mention', 'report', 'follow_request']
                    && request.resource.data.read == false
                    && (
                      request.resource.data.type != 'report'
                      || request.resource.data.recipientId == 'gHHxF8p1DnbMkoeVmU5XpB18Elz2'
                    );
      allow read: if isSignedIn()
                  && resource.data.recipientId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.recipientId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
